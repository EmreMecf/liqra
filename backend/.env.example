# ── Claude API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Sunucu ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Veritabanı (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/muhasebe_db

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=guclu-rastgele-anahtar-buraya
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AI_RATE_LIMIT_PER_HOUR=20
GLOBAL_RATE_LIMIT_PER_MIN=60

# ── Piyasa Veri API'leri ──────────────────────────────────────────────────────
COLLECT_API_KEY=...
BINANCE_API_URL=https://api.binance.com

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Firebase Console > Proje Ayarları > Hizmet Hesapları > Yeni Özel Anahtar Oluştur
# İndirilen JSON'ı base64'e çevir: base64 -i serviceAccount.json
FIREBASE_SERVICE_ACCOUNT_BASE64=...

# ── Super Admin (Firma Onboarding) ────────────────────────────────────────────
# POST /api/auth/merchant/onboard endpoint'ini korur.
# Güçlü, rastgele bir değer kullan: openssl rand -hex 32
SUPER_ADMIN_SECRET=guclu-rastgele-secret-buraya

# ── Claude Model ──────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2000
