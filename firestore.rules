rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════════════════

    // Giriş yapan user'ı kontrol et
    function isSignedIn() {
      return request.auth != null;
    }

    // Kendi dokumentine mi erişiyor?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User'ın rolünü al
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Merchant admin mı?
    function isMerchantAdmin(userId) {
      return getUserRole(userId) == 'merchant_admin';
    }

    // Merchant cashier mı?
    function isMerchantCashier(userId) {
      return getUserRole(userId) == 'merchant_cashier';
    }

    // Merchant employee mi? (admin veya cashier)
    function isMerchantEmployee(userId) {
      return isMerchantAdmin(userId) || isMerchantCashier(userId);
    }

    // ════════════════════════════════════════════════════════════════════════════
    // PERSONAL USER DATA — Kişiye özel veriler
    // ════════════════════════════════════════════════════════════════════════════

    match /users/{userId} {
      // Tüm sub-collections: Owner sadece
      match /{document=**} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
    }

    // ════════════════════════════════════════════════════════════════════════════
    // MERCHANT OPERATIONS — İşletme verileri
    // ════════════════════════════════════════════════════════════════════════════

    match /merchant_operations/{merchantId} {
      // Dashboard: merchant_admin sadece
      match /dashboard {
        allow read, write: if isSignedIn() && 
          request.auth.uid == merchantId && 
          isMerchantAdmin(request.auth.uid);
      }

      // Transactions: admin yazabilir, admin+cashier okuyabilir
      match /transactions/{transactionId} {
        allow read: if isSignedIn() && 
          request.auth.uid == merchantId && 
          isMerchantEmployee(request.auth.uid);
        allow create: if isSignedIn() && 
          request.auth.uid == merchantId && 
          isMerchantEmployee(request.auth.uid);
        allow update, delete: if isSignedIn() && 
          request.auth.uid == merchantId && 
          isMerchantAdmin(request.auth.uid);
      }

      // Reports: merchant_admin sadece
      match /reports/{reportId} {
        allow read, write: if isSignedIn() && 
          request.auth.uid == merchantId && 
          isMerchantAdmin(request.auth.uid);
      }

      // Staff: merchant_admin sadece
      match /staff/{staffId} {
        allow read, write: if isSignedIn() && 
          request.auth.uid == merchantId && 
          isMerchantAdmin(request.auth.uid);
      }

      // Settings: merchant_admin sadece
      match /settings {
        allow read, write: if isSignedIn() && 
          request.auth.uid == merchantId && 
          isMerchantAdmin(request.auth.uid);
      }
    }

    // ════════════════════════════════════════════════════════════════════════════
    // PUBLIC DATA — Tüm kullanıcılar okuyabilir
    // ════════════════════════════════════════════════════════════════════════════

    match /market/live_prices {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /tefas_funds/{fundCode} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /bank_campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /news/{newsId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /meta/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DEFAULT: HER ŞEY YASAK
    // ════════════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
